# Secrets -- never commit
.env

# Runtime state -- never commit (so pulls don't clobber the server's live data).
# themes.json IS tracked (it's config); the queues/settings are runtime.
data/pending.json
data/approved.json
data/history.json
data/settings.json

# Per-account (multi-tenant) data -- holds Facebook tokens + each account's
# queues, cards, brand, and logo. NEVER commit (secrets + runtime state).
# On first run the app migrates the legacy data/ + assets/ + .env into
# tenants/skysystems/, then this dir is the live per-account store.
tenants/

# Generated runtime artifacts (regenerated each run)
data/dry_runs/
data/cards/
assets/style_previews/

# Logs
*.log
logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
