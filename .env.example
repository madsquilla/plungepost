# PlungePost -- environment variables
# Copy this file to .env and fill in real values. NEVER commit your real .env.

# --- Anthropic (content generation) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Meta Graph API (publishing) ---
# Legacy single-account Facebook Page ID (new accounts store creds per account).
META_PAGE_ID=000000000000000
# Long-lived Page access token (you generate this separately; see README).
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Pexels (topic-relevant stock photos for post graphics) ---
# Free key from https://www.pexels.com/api/ . If omitted, posts fall back to
# clean text-only branded cards (no photo).
PEXELS_API_KEY=your-free-pexels-api-key

# --- Dashboard / scheduler ---
# Time zone used by the dashboard's scheduler + auto-pilot (IANA name).
TZ=America/Chicago

# --- Optional overrides (sane defaults exist in code) ---
# ANTHROPIC_MODEL=claude-opus-4-8
# CANONICAL_URL=https://skyusa.us
# PORT=8080            # dashboard port
# FLASK_SECRET=change-me
